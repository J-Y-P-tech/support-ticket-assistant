# Example environment file — copy to `.env` and fill in real values.
# NEVER commit the real `.env` (it is gitignored). No real secrets belong here.

# --- PostgreSQL (used by docker-compose.yml; email_mcp is the sole DB owner) ---
POSTGRES_USER=support
POSTGRES_PASSWORD=change-me
POSTGRES_DB=support_tickets
POSTGRES_PORT=5432
# Host to reach Postgres on. `localhost` for host-run `make migrate` (compose
# exposes the port); in-compose services override this to the `postgres` service name.
POSTGRES_HOST=localhost

# --- Host ports the compose stack publishes (optional; sensible defaults in compose) ---
# Only the host-side mapping; in-cluster ports are fixed (api/email_mcp :8000,
# frontend :8501). email_mcp keeps host 8000 for the opt-in live integration test.
EMAIL_MCP_PORT=8000
API_PORT=8001
FRONTEND_PORT=8501

# --- LLM: single multimodal model on the host, reached via host.docker.internal ---
LLM_MODEL=gemma4:12b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Retrieval / pagination sizing (tuning knobs shared by the api and the MCP
#     servers; a single value here is the source of truth for both sides) ---
# Max ranked KB sources a search returns (kb_mcp reads this too):
KB_SEARCH_LIMIT=3
# Rep-queue page size when the client requests none, and the hard ceiling a
# client can never exceed (email_mcp reads QUEUE_PAGE_DEFAULT too):
QUEUE_PAGE_DEFAULT=50
QUEUE_PAGE_MAX=200

# --- Agent node behaviour ---
# How many times triage asks the model for a valid classification before the case
# is handed to a human rep (1 = no retry; 2 = one retry, the SPEC §4.3 default):
TRIAGE_MAX_ATTEMPTS=2
# Groundedness threshold for a drafted reply: the minimum score (0.0-1.0) the
# LLM-as-judge must assign — the fraction of the reply's factual claims its cited
# sources support — before the draft is flagged "AI-suggested, unverified" for the
# rep. 0.6 = moderate (SPEC §4.5); tune to taste.
GROUNDEDNESS_MIN=0.6
# How many times the groundedness judge is asked for a valid verdict before the node
# fails closed and flags the draft for manual review (1 = no retry; 2 = one retry):
VALIDATE_MAX_ATTEMPTS=2
# How many times the attachment-extraction pass asks the model for a valid structured
# record before flagging "could not extract" and surfacing the raw text to the rep
# (1 = no retry; 2 = one retry, the SPEC §4.2 default):
EXTRACT_MAX_ATTEMPTS=2
# How many recent APPROVED replies (for the ticket's category) the drafting node injects
# as dynamic few-shot examples (SPEC §4.10); 0 disables few-shot injection entirely:
FEW_SHOT_LIMIT=3

# --- LangGraph checkpointer store (the api persists paused runs here so a case
#     awaiting human review survives a restart; SPEC §3/§5). Same Postgres as
#     email_mcp; LangGraph creates its own tables. Host `postgres` in-compose. ---
DATABASE_URL=postgresql://support:change-me@postgres:5432/support_tickets

# --- Inter-service auth: a separate bearer token per connection (least privilege) ---
# Base URL the frontend uses to reach the api (compose service name in-cluster):
API_BASE_URL=http://api:8000
# Token the frontend presents to the api:
API_AUTH_TOKEN=change-me-frontend-to-api
# api -> email_mcp (streamable-HTTP MCP endpoint; email_mcp serves at /mcp):
EMAIL_MCP_URL=http://email_mcp:8000/mcp
EMAIL_MCP_TOKEN=change-me-api-to-email
# api -> kb_mcp (streamable-HTTP MCP endpoint; kb_mcp serves at /mcp):
KB_MCP_URL=http://kb_mcp:8000/mcp
KB_MCP_TOKEN=change-me-api-to-kb

# --- Application-layer encryption for PII at rest (Fernet key; generate a real one) ---
ENCRYPTION_KEY=change-me-base64-fernet-key

# --- Langfuse observability (self-hosted) ---
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_SECRET_KEY=sk-lf-change-me
